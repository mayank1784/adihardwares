    <script>
      $(window).on('load', function() {
        // Fallback to remove preloader when everything is loaded
        $('#preloader').fadeOut('slow');
      });
      
      // Remove preloader earlier for better perceived performance
      document.addEventListener("DOMContentLoaded", function() {
        setTimeout(function() {
          $('#preloader').fadeOut('slow');
        }, 800); // Show animation for at least 800ms
      });
    </script>
