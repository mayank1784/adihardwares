    <style>
        .preloader {
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background-color: #fff;
          display: flex;
          justify-content: center;
          align-items: center;
          z-index: 9999;
          transition: opacity 0.5s ease;
        }
        
        .zoom-logo {
          width: 150px; /* Adjust as needed */
          animation: zoomInOut 1.5s infinite ease-in-out;
        }

        @keyframes zoomInOut {
          0% {
            transform: scale(1);
          }
          50% {
            transform: scale(1.3);
          }
          100% {
            transform: scale(1);
          }
        }
    </style>
    
    <div class="preloader" id="preloader">
      <img src="images/new-logo.png" alt="Adi Hardwares" class="zoom-logo" />
    </div>
    
